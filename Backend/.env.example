# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB connection string.
# Local:  mongodb://127.0.0.1:27017/nestlist
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nestlist
MONGO_URI=mongodb://127.0.0.1:27017/nestlist

# Server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=30d

# Allow the Expo app to call this API. Set to your machine's LAN IP / Expo
# tunnel origin in development; lock down to your real domain in production.
CORS_ORIGIN=*

# Seed script — the first admin account it creates
SEED_ADMIN_NAME=Society Admin
SEED_ADMIN_PHONE=9999900000
SEED_ADMIN_PASSWORD=admin123
